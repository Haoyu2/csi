# Ignore large raw and processed data
CSI/
BVP/
Gait_Dataset/
python_pipeline/output/

# Archives and raw captures
*.zip
*.dat
*.pcap

# Model artifacts
*.h5
*.npz
*.mat

# Python / tooling noise
__pycache__/
*.pyc
.idea/
.vs/
.DS_Store

# IDE / notebook checkpoints
.ipynb_checkpoints/

# Explicitly track DNN_Model data overriding the glob ignores
!DNN_Model/bap_data/
!DNN_Model/bap_data/**/*.npz
!DNN_Model/bvp_data/
!DNN_Model/bvp_data/**/*.npz
!DNN_Model/bvp_data/**/*.mat
